# NightOut Mobile — Environment Variables
# Copy to .env and fill in values from the main NightOut web app.

# Supabase (same as web app)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Search API base (Browse, /api/search): ${EXPO_PUBLIC_SEARCH_API_URL}/api/search
# Production example: https://pulse.techies.com
EXPO_PUBLIC_SEARCH_API_URL=
#
# Concierge: POST ${EXPO_PUBLIC_SEARCH_API_URL}/api/concierge (ParadeDB) vs Supabase Edge concierge_chat
# - Production (__DEV__ false): Edge is used unless EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION is exactly false.
#   Commenting out the variable does NOT disable Edge — set false explicitly for direct Pulse.
# - Dev: set EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=true to use Edge; otherwise Node needs SEARCH_API_URL above.
# EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=false
#
# Local dev (physical device): LAN IP for your PC — NOT localhost. Android emulator: http://10.0.2.2:3001
