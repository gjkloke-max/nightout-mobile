# NightOut Mobile — Environment Variables
# Copy to .env and fill in values from the main NightOut web app.

# Supabase (same as web app)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Search API base (Browse, /api/search): ${EXPO_PUBLIC_SEARCH_API_URL}/api/search
# Production example: https://pulse.techies.com
EXPO_PUBLIC_SEARCH_API_URL=
#
# Concierge: with EXPO_PUBLIC_SEARCH_API_URL set, the app uses Pulse Node POST …/api/concierge (same as Browse search).
# Use Supabase Edge concierge_chat only if you set EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=true.
# If SEARCH_API_URL is unset, Edge is used in production unless EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=false.
# EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=true
#
# Concierge client abort (ms). Default 300000 (5 min). Neighborhood queries can be slow; if you set this,
# use at least 120000–180000 or you may see timeouts before Pulse finishes. Example: EXPO_PUBLIC_CONCIERGE_TIMEOUT_MS=180000
# EXPO_PUBLIC_CONCIERGE_TIMEOUT_MS=

# Local dev (physical device): LAN IP for your PC — NOT localhost. Android emulator: http://10.0.2.2:3001
