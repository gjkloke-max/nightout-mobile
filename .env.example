# NightOut Mobile — Environment Variables
# Copy to .env and fill in values from the main NightOut web app.

# Supabase (same as web app)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Search API base (Browse, hybrid search, etc.): ${EXPO_PUBLIC_SEARCH_API_URL}/api/search
# Production example: https://pulse.techies.com
#
# Concierge: by default uses Supabase Edge `concierge_chat` (same as web). Setting SEARCH_API_URL does NOT force
# Node /api/concierge anymore (that path was timing out on mobile). To use Node concierge instead:
#   EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=false
# and keep SEARCH_API_URL set.
#
# Local dev (physical device): LAN IP for your PC — NOT localhost. Android emulator: http://10.0.2.2:3001
# Dev without SEARCH_API_URL: set EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=true to test Edge, or set SEARCH_API_URL for local Node.
EXPO_PUBLIC_SEARCH_API_URL=
# EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=true   # dev: force Edge; omit in prod for Edge default
# EXPO_PUBLIC_USE_CONCIERGE_EDGE_FUNCTION=false  # prod: force Node /api/concierge (needs URL above)
